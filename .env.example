# ─── Bright Capital CRM — Environment Variables ───────────────────────────────
# LOCAL:      copy this to .env
# PRODUCTION: add in Vercel → Settings → Environment Variables → Redeploy

# ── Storage (choose ONE) ───────────────────────────────────────────────────────

# Option A — GitHub Gist (recommended: no new account needed)
# Setup (2 min):
#   1. github.com/settings/tokens → Generate new token (classic)
#   2. Name it anything, tick ONLY the "gist" scope → Generate → copy
#   3. Paste below / add to Vercel env vars as GH_TOKEN
#   The backend auto-creates a private Gist on first run. Data persists forever.
GH_TOKEN=ghp_your_token_here

# Option B — Upstash Redis (alternative)
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token

# ── Gmail email notifications ──────────────────────────────────────────────────
# Setup: myaccount.google.com → Security → App passwords → generate for "Mail"
GMAIL_USER=yannickngongo14@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
NOTIFY_EMAIL=yannickngongo14@gmail.com

# ── CRM dashboard password ─────────────────────────────────────────────────────
CRM_PASSWORD=BrightCapital2025
