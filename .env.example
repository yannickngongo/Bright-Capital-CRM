# ─── Bright Capital CRM — Environment Variables ───────────────────────────────
# LOCAL: copy this to .env
# PRODUCTION: add these in Vercel dashboard → Settings → Environment Variables

# ── Gmail email notifications ──────────────────────────────────────────────────
# One-time setup (2 min):
#   1. myaccount.google.com → Security → 2-Step Verification (enable)
#   2. Security → App passwords → Generate for "Mail"
#   3. Paste the 16-char password below
GMAIL_USER=yannickngongo14@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
NOTIFY_EMAIL=yannickngongo14@gmail.com

# ── CRM dashboard password ─────────────────────────────────────────────────────
CRM_PASSWORD=BrightCapital2025

# ── Upstash Redis (persistent storage for production) ──────────────────────────
# One-time setup (2 min):
#   1. upstash.com → Sign in with GitHub (free, no credit card)
#   2. Create Database → Name: bright-capital-crm → Region: US-East-1 → Free → Create
#   3. Click "Connect" tab → copy REST URL and REST Token below
#   If not set, the backend falls back to a local JSON file (fine for development)
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here
